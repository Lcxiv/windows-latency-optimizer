# Large binary captures — track CSV/JSON/TXT, ignore binary traces
captures/*.pml
captures/*.etl
captures/*.bl
captures/**/*.etl
captures/**/*.pdb
captures/**/events.csv
captures/**/report.xml
captures/**/*.NGENPDB/

# Archived experiment data (kept locally, not pushed)
captures/archive/

# Audit output (regenerated on each run)
captures/audits/*.json
captures/audits/*.html
captures/audits/*.ps1
captures/audits/history.csv

# OS artifacts
Thumbs.db
desktop.ini
.DS_Store

# Editor
.vscode/
*.code-workspace

# Temp and log files
*.tmp
*.cache
*.bak

# Node
node_modules/
package-lock.json

# Tauri / Rust build
latencyguard/src-tauri/target/
latencyguard/src-tauri/gen/
latencyguard/node_modules/

# Brainstorm sessions
.superpowers/

# Local captures (not tracked — regenerated per machine)
captures/backup_pre_*.txt
captures/experiments/

# Local settings
.claude/settings.local.json


# Large binary captures — track CSV/JSON/TXT, ignore binary traces
captures/*.pml
captures/*.etl
captures/*.bl
captures/**/*.etl
captures/**/*.pdb
captures/**/events.csv
captures/**/report.xml
captures/**/*.NGENPDB/

# Archived experiment data (kept locally, not pushed)
captures/archive/

# Audit output (regenerated on each run)
captures/audits/*.json
captures/audits/*.html
captures/audits/*.ps1
captures/audits/history.csv

# OS artifacts
Thumbs.db
desktop.ini
.DS_Store

# Editor
.vscode/
*.code-workspace

# Temp and log files
*.tmp
*.cache
*.bak

# Node (npx serve only)
node_modules/
package-lock.json

# If you want to exclude large CSVs from the repo, uncomment:
# captures/*.csv
